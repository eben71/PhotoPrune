# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=photoprune
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/photoprune

# Cache / Queue
REDIS_URL=redis://redis:6379/0

# API
# PhotoPrune supports only one trusted operator on this machine.
DEPLOYMENT_MODE=local_only
# Exact values: local, test, production
ENVIRONMENT=local
# Compose uses same-origin web routes and may leave CORS disabled. Direct
# non-container development may use these explicit loopback browser origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REQUEST_BODY_MAX_BYTES=33554432
SCAN_MAX_PHOTOS=250
SCAN_CONSENT_THRESHOLD=200
# Empty/unset denies every download in all environments. Exact hostnames only;
# googleusercontent.com is the explicit policy token for lh<digits> media hosts.
SCAN_ALLOWED_DOWNLOAD_HOSTS=googleusercontent.com
# Local/test fixture rewrites only. The original hostname must also be allowlisted.
# Example: SCAN_ALLOWED_DOWNLOAD_HOSTS=example.test with
# SCAN_DOWNLOAD_HOST_OVERRIDES=example.test:http://127.0.0.1:8001
SCAN_DOWNLOAD_HOST_OVERRIDES=
SCAN_DOWNLOAD_MAX_BYTES_PER_ITEM=52428800
SCAN_DOWNLOAD_MAX_BYTES_PER_SCAN=524288000
SCAN_DOWNLOAD_MAX_REDIRECTS=3
SCAN_DOWNLOAD_TIMEOUT_SECONDS=30
SCAN_DOWNLOAD_WALL_SECONDS=600
SCAN_CONCURRENCY_LIMIT=1
SCAN_ADMISSIONS_PER_MINUTE=5
API_REQUESTS_PER_MINUTE=120
SCAN_DHASH_THRESHOLD_VERY=5
SCAN_DHASH_THRESHOLD_POSSIBLE=10
SCAN_PHASH_THRESHOLD_VERY=6
SCAN_PHASH_THRESHOLD_POSSIBLE=12
SCAN_COST_PER_DOWNLOAD=0.0002
SCAN_COST_PER_BYTE_HASH=0.00005
SCAN_COST_PER_PERCEPTUAL_HASH=0.00008
SCAN_COST_PER_COMPARISON=0.00001
SCAN_SMALL_INPUT_FALLBACK_MAX=20
SCAN_EXPLAIN=0

# Web
# Server-side forwarding inside Compose is set by docker-compose.yml:
# INTERNAL_API_BASE_URL=http://api:8000
# Loopback fallback for explicit non-container development only.
PHOTOPRUNE_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_APP_ID=
